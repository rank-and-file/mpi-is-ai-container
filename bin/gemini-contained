#!/bin/sh
CONTAINER="/fast/${USER}/containers/ai-tools.sif"
TMPDIR_HOST="/fast/${USER}/ai-container-tmp"
mkdir -p "$TMPDIR_HOST"
BINDS="--bind $PWD --bind $HOME/.gemini --bind ${TMPDIR_HOST}:/tmp"
exec apptainer exec --nv --writable-tmpfs --contain $BINDS --pwd "$PWD" "$CONTAINER" gemini --yolo "$@"
