#!/bin/sh
CONTAINER="/fast/${USER}/containers/ai-tools.sif"
TMPDIR_HOST="/fast/${USER}/ai-container-tmp"
mkdir -p "$TMPDIR_HOST"
BINDS="--bind $PWD --bind $HOME/.claude --bind $HOME/.claude.json --bind /fast/${USER} --bind ${TMPDIR_HOST}:/tmp"
exec apptainer exec --nv --writable-tmpfs --contain $BINDS --pwd "$PWD" "$CONTAINER" claude --dangerously-skip-permissions "$@"
